menu "ESP32 MQTT Sensor configuration"

config WIFI_SSID
    string "WiFi SSID"
    default ""

config WIFI_PASSWORD
    string "WiFi Password"
    default ""

config MQTT_URI
    string "MQTT Broker URI"
    default "mqtt://192.168.1.100"

config MQTT_USERNAME
    string "MQTT Username"
    default ""

config MQTT_PASSWORD
    string "MQTT Password"
    default ""

config MQTT_TOPIC
    string "MQTT Publish Topic"
    default "esp32_mqtt_sensor"

config REPORT_INTERVAL_S
    int "Reporting interval (seconds)"
    default 60

config BAT_ADC_CHANNEL
    int "ADC1 channel (0..7) for battery input (ADC1_CHANNEL_0 = 0)"
    default 0

config BATTERY_DIVIDER_R1
    int "Voltage divider R1 (ohms) -- top resistor"
    default 100000

config BATTERY_DIVIDER_R2
    int "Voltage divider R2 (ohms) -- bottom resistor"
    default 100000

config BATTERY_MIN_MV
    int "Battery voltage (mV) corresponding to 0%"
    default 3000

config BATTERY_MAX_MV
    int "Battery voltage (mV) corresponding to 100%"
    default 4200

config DISTANCE_MIN_MM
    int "Minimum distance (mm) corresponding to 0%"
    default 50

config DISTANCE_MAX_MM
    int "Maximum distance (mm) corresponding to 100%"
    default 2000

config VL53L0X_ENABLE
    bool "VL53L0X distance sensor support"
    default y
    help
        Internal symbol. Selected by the distance sensor choice when VL53L0X
        is chosen. Do not enable directly.

config VL53L1X_ENABLE
    bool "VL53L1X distance sensor support"
    default y
    help
        Internal symbol. Selected by the distance sensor choice when VL53L1X
        is chosen. Do not enable directly.

config TL136_ENABLE
    bool "TL-136 distance sensor support"
    default y
    help
        Internal symbol. Selected by the distance sensor choice when TL-136
        is chosen. Do not enable directly.

config TL136_ADC_CHANNEL
        int "ADC1 channel for TL-136 (e.g. 1 for GPIO1)"
        default 1
        help
            ADC1 channel number used to read the TL-136 analog output.

config TL136_MAX_DISTANCE_MM
        int "TL-136 maximum distance (mm)"
        default 5000
        help
            Maximum distance (in millimetres) used for linear mapping of ADC
            readings to distance output.

config TL136_MIN_DISTANCE_MM
        int "TL-136 minimum distance (mm)"
        default 0
        help
            Minimum distance (in millimetres) used for linear mapping of ADC
            readings to distance output.

config TL136_POWER_ON_GPIO
        int "TL-136 power-on GPIO (use 18 for none)"
        default 18
        help
            GPIO number used to power on or enable the TL-136 sensor. If 
            set to -1, the driver will not attempt to control a power-on pin.

config TL136_RESISTOR_R1_OHMS
        int "TL-136 voltage divider resistor R1 (ohms)"
        default 100
        help        
            Value of resistor R1 in the voltage divider used for the TL-136 sensor
            (the resistor between the sensor output and ADC input).

config TL136_RANGE_MM
        int "TL-136 range (mm)"
        default 5000
        help
            Range of the TL-136 sensor in millimetres. This is used to calculate
            the current corresponding to the maximum distance, based on the
            configured voltage divider resistor R1 and the TL-136 current limits.

endmenu
